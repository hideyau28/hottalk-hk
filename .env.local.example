# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Revalidation
REVALIDATION_SECRET=your-revalidation-secret

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# Google Trends (optional SerpApi fallback)
SERPAPI_KEY=your-serpapi-key

# LIHKG Proxy
PROXY_A_URL=https://your-proxy-a.example.com
PROXY_B_URL=https://your-proxy-b.example.com

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# QStash (webhook signature verification)
QSTASH_CURRENT_SIGNING_KEY=your-current-key
QSTASH_NEXT_SIGNING_KEY=your-next-key

# Admin Auth (comma-separated admin emails)
ADMIN_EMAILS=admin@example.com

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
