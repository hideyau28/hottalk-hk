{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["hkg1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/collect", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/assign", "schedule": "3,13,23,33,43,53 * * * *" },
    { "path": "/api/cron/nightly", "schedule": "0 18 * * *" },
    { "path": "/api/cron/daily-brief", "schedule": "0 4 * * *" }
  ]
}
