{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["hkg1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/pipeline",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-brief",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/nightly",
      "schedule": "0 18 * * *"
    }
  ]
}
